<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Big Win - Sign Up</title>
<link rel="stylesheet" href="css/style.css">
</head>

<body>

<div class="login-box">

<h1>Create Account</h1>

<input type="text" placeholder="Full Name">

<input type="email" placeholder="Email">

<input type="password" placeholder="Password">

<button>Create Account</button>

<p>Already have an account?</p>

<a href="login.html">Login</a>

</div>

</body>
</html>
.login-box{
width:350px;
margin:80px auto;
background:#222;
padding:30px;
border-radius:15px;
text-align:center;
}

.login-box input{
width:90%;
padding:12px;
margin:10px 0;
border:none;
border-radius:8px;
font-size:16px;
}

.login-box button{
width:95%;
padding:12px;
background:gold;
border:none;
border-radius:8px;
font-size:18px;
cursor:pointer;
}

.login-box a{
color:gold;
text-decoration:none;
}
